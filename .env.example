# 必需 — DashScope API Key（Qwen-VL / Qwen-Plus / Paraformer ASR）
DASHSCOPE_API_KEY=sk-xxx

# 必需 — 阿里云 RAM 子账号 AK/SK（AliyunOCRFullAccess 权限）
ALIYUN_ACCESS_KEY_ID=LTAI5t...
ALIYUN_ACCESS_KEY_SECRET=...

# OCR / VLM / 聚合 LLM 配置
EMPHASIS_OCR_PROVIDER=aliyun
EMPHASIS_OCR_AREA_THRESHOLD=0.003
EMPHASIS_OCR_MODE=rows
EMPHASIS_VLM_MODEL=qwen3.6-flash
EMPHASIS_AGG_MODEL=qwen-plus
EMPHASIS_TASK_TIMEOUT_MS=60000

# ASR（sentenceAnchors 反推）
EMPHASIS_ASR_MODEL=paraformer-v2
EMPHASIS_ASR_TIMEOUT_MS=60000
EMPHASIS_ASR_ENABLED=true

# HyperFrames 渲染
HYPERFRAMES_CHROME_PATH=
EMPHASIS_RENDER_TIMEOUT_MS=180000

# 服务配置
PORT=3200
MEDIA_DIR=./media
DATA_DIR=./data

# 可选 API Key 鉴权（留空则不鉴权）
API_KEY=
